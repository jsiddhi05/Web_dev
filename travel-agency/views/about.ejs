<%- include('partials/header') %>

<section class="page-hero">
  <div class="page-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=1400')"></div>
  <div class="page-hero-content">
    <h1>About Travel World</h1>
    <p>Crafting unforgettable journeys since 2010</p>
  </div>
</section>

<section class="section about-intro">
  <div class="container about-grid">
    <div class="about-img-wrap">
      <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=700" alt="Our Team" class="about-img" />
      <div class="about-badge"><span class="badge-num">15+</span><span>Years of Excellence</span></div>
    </div>
    <div class="about-text">
      <span class="section-tag">Our Story</span>
      <h2 class="section-title">We Live &amp; Breathe Travel</h2>
      <p>Founded in 2010, Travel World began with a single vision: to make extraordinary travel accessible to everyone. What started as a small team of passionate explorers has grown into one of India's most trusted travel agencies.</p>
      <p>We've helped over 12,000 travellers experience the world's most breathtaking destinations — from the temples of Kyoto to the plains of the Serengeti. Every trip we curate is built on deep local knowledge, trusted partnerships, and a relentless commitment to your experience.</p>
      <div class="about-stats">
        <div class="astat"><span>12K+</span><p>Happy Travelers</p></div>
        <div class="astat"><span>50+</span><p>Destinations</p></div>
        <div class="astat"><span>98%</span><p>Satisfaction Rate</p></div>
      </div>
    </div>
  </div>
</section>

<section class="section team-section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Our People</span>
      <h2 class="section-title">Meet the Team</h2>
      <p>Passionate travellers who turn your dreams into itineraries</p>
    </div>
    <div class="team-grid">
      <div class="team-card">
        <div class="team-photo" style="background:linear-gradient(135deg,#f5a623,#e67e22)"><span>RK</span></div>
        <h3>Rahul Kapoor</h3>
        <p class="team-role">Founder & CEO</p>
        <p>A globetrotter with 20+ years of travel experience across 60 countries.</p>
      </div>
      <div class="team-card">
        <div class="team-photo" style="background:linear-gradient(135deg,#4facfe,#00f2fe)"><span>PS</span></div>
        <h3>Priya Sharma</h3>
        <p class="team-role">Head of Experiences</p>
        <p>Specialises in bespoke cultural and wildlife expeditions across Asia and Africa.</p>
      </div>
      <div class="team-card">
        <div class="team-photo" style="background:linear-gradient(135deg,#43e97b,#38f9d7)"><span>AM</span></div>
        <h3>Aryan Mehta</h3>
        <p class="team-role">Adventure Lead</p>
        <p>Certified mountain guide and adventure travel expert with a passion for peaks.</p>
      </div>
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="cta-content">
    <h2>Ready to Explore the World?</h2>
    <p>Browse our handcrafted tours and start your next adventure today.</p>
    <a href="/tours" class="btn btn-primary btn-lg">View All Tours</a>
  </div>
</section>

<%- include('partials/footer') %>
