<%- include('partials/header') %>

<!-- Hero Section -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <span class="hero-badge">✈ Discover the World</span>
    <h1 class="hero-title">Your Journey<br><em>Begins Here</em></h1>
    <p class="hero-sub">Handcrafted travel experiences across 50+ destinations. From tropical beaches to mountain peaks — we make every trip unforgettable.</p>
    <div class="hero-actions">
      <a href="/tours" class="btn btn-primary btn-lg">Explore Tours</a>
      <a href="/about" class="btn btn-ghost btn-lg">Learn More</a>
    </div>
    <div class="hero-stats">
      <div class="stat"><span class="stat-num">50+</span><span class="stat-label">Destinations</span></div>
      <div class="stat-divider"></div>
      <div class="stat"><span class="stat-num">12K+</span><span class="stat-label">Happy Travelers</span></div>
      <div class="stat-divider"></div>
      <div class="stat"><span class="stat-num">15</span><span class="stat-label">Years Experience</span></div>
    </div>
  </div>
  <div class="hero-scroll"><span>Scroll</span><i class="fas fa-chevron-down"></i></div>
</section>

<!-- Search Bar -->
<section class="search-section">
  <div class="search-card">
    <form action="/tours" method="GET" class="search-form">
      <div class="search-field">
        <label><i class="fas fa-search"></i> Search</label>
        <input type="text" name="search" placeholder="Where do you want to go?" />
      </div>
      <div class="search-field">
        <label><i class="fas fa-tag"></i> Category</label>
        <select name="category">
          <option value="All">All Categories</option>
          <option value="Beach">Beach</option>
          <option value="Adventure">Adventure</option>
          <option value="Cultural">Cultural</option>
          <option value="Wildlife">Wildlife</option>
          <option value="Mountain">Mountain</option>
          <option value="City">City</option>
        </select>
      </div>
      <button type="submit" class="btn btn-primary">Search Tours</button>
    </form>
  </div>
</section>

<!-- Featured Tours -->
<section class="section featured-tours">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Featured</span>
      <h2 class="section-title">Most Popular Tours</h2>
      <p>Handpicked experiences our travelers love the most</p>
    </div>
    <div class="tours-grid">
      <% if (featuredTours && featuredTours.length > 0) { %>
        <% featuredTours.forEach(tour => { %>
          <div class="tour-card">
            <div class="tour-img" style="background-image: url('<%= tour.image %>')">
              <span class="tour-category"><%= tour.category %></span>
              <div class="tour-overlay"></div>
            </div>
            <div class="tour-body">
              <div class="tour-rating">
                <i class="fas fa-star"></i>
                <span><%= tour.rating %></span>
                <span class="reviews">(<%= tour.reviews %> reviews)</span>
              </div>
              <h3 class="tour-name"><%= tour.name %></h3>
              <p class="tour-dest"><i class="fas fa-map-marker-alt"></i> <%= tour.destination %></p>
              <p class="tour-duration"><i class="fas fa-clock"></i> <%= tour.duration %></p>
              <div class="tour-footer">
                <div class="tour-price">
                  <span class="price-label">From</span>
                  <span class="price-value">$<%= tour.price.toLocaleString() %></span>
                </div>
                <a href="/tours/<%= tour._id %>" class="btn btn-sm btn-primary">View Tour</a>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p class="no-data">No tours available. <a href="/seed">Seed the database</a>.</p>
      <% } %>
    </div>
    <div class="center-btn">
      <a href="/tours" class="btn btn-outline-dark btn-lg">View All Tours <i class="fas fa-arrow-right"></i></a>
    </div>
  </div>
</section>

<!-- Why Choose Us -->
<section class="section why-us">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Why Us</span>
      <h2 class="section-title">Travel With Confidence</h2>
    </div>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
        <h3>100% Safe Travel</h3>
        <p>Your safety is our top priority. All tours are carefully vetted and follow international safety standards.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><i class="fas fa-medal"></i></div>
        <h3>Expert Local Guides</h3>
        <p>Our certified guides bring destinations to life with insider knowledge and genuine passion.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><i class="fas fa-headset"></i></div>
        <h3>24/7 Support</h3>
        <p>Round-the-clock customer support ensures you're never alone on your journey.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><i class="fas fa-tag"></i></div>
        <h3>Best Price Guarantee</h3>
        <p>We match any lower price — or give you the difference back. No questions asked.</p>
      </div>
    </div>
  </div>
</section>

<!-- Destinations Banner -->
<section class="destinations-banner">
  <div class="dest-grid">
    <div class="dest-item dest-large" style="background-image: url('https://images.unsplash.com/photo-1537996194471-e657df975ab4?w=800')">
      <div class="dest-overlay"></div>
      <div class="dest-info">
        <span>Indonesia</span>
        <h3>Bali</h3>
      </div>
    </div>
    <div class="dest-item" style="background-image: url('https://images.unsplash.com/photo-1570077188670-e3a8d69ac5ff?w=800')">
      <div class="dest-overlay"></div>
      <div class="dest-info">
        <span>Greece</span>
        <h3>Santorini</h3>
      </div>
    </div>
    <div class="dest-item" style="background-image: url('https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?w=800')">
      <div class="dest-overlay"></div>
      <div class="dest-info">
        <span>Japan</span>
        <h3>Kyoto</h3>
      </div>
    </div>
    <div class="dest-item" style="background-image: url('https://images.unsplash.com/photo-1516426122078-c23e76319801?w=800')">
      <div class="dest-overlay"></div>
      <div class="dest-info">
        <span>Tanzania</span>
        <h3>Serengeti</h3>
      </div>
    </div>
  </div>
</section>

<!-- Testimonials -->
<section class="section testimonials">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Testimonials</span>
      <h2 class="section-title">What Travelers Say</h2>
    </div>
    <div class="testimonials-grid">
      <div class="testimonial-card">
        <div class="stars">★★★★★</div>
        <p>"The Bali tour was absolutely magical. Everything was perfectly organised and our guide was incredible!"</p>
        <div class="reviewer">
          <div class="reviewer-avatar">SK</div>
          <div><strong>Sneha Kapoor</strong><span>Mumbai, India</span></div>
        </div>
      </div>
      <div class="testimonial-card featured-testimonial">
        <div class="stars">★★★★★</div>
        <p>"Santorini with Travel World was a dream come true. The sunset cruise, the food, the boutique hotel — all perfection."</p>
        <div class="reviewer">
          <div class="reviewer-avatar">MR</div>
          <div><strong>Marco Rossi</strong><span>Milan, Italy</span></div>
        </div>
      </div>
      <div class="testimonial-card">
        <div class="stars">★★★★★</div>
        <p>"The Machu Picchu trek was challenging but the team supported us at every step. Worth every rupee!"</p>
        <div class="reviewer">
          <div class="reviewer-avatar">AP</div>
          <div><strong>Arjun Patel</strong><span>Delhi, India</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA Section -->
<section class="cta-section">
  <div class="cta-content">
    <h2>Ready for Your Next Adventure?</h2>
    <p>Join thousands of happy travelers. Book your dream tour today.</p>
    <div class="cta-actions">
      <a href="/tours" class="btn btn-primary btn-lg">Browse Tours</a>
      <% if (!user) { %>
        <a href="/auth/register" class="btn btn-outline btn-lg">Create Account</a>
      <% } %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
