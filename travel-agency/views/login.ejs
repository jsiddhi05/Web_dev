<%- include('partials/header') %>

<section class="auth-page">
  <div class="auth-bg" style="background-image: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1400')"></div>
  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-illustration">
        <div class="illustration-content">
          <h2>Welcome Back!</h2>
          <p>Log in to manage your bookings and explore new destinations</p>
          <div class="auth-features">
            <div><i class="fas fa-check"></i> Access your bookings</div>
            <div><i class="fas fa-check"></i> Save favourite tours</div>
            <div><i class="fas fa-check"></i> Exclusive member deals</div>
          </div>
        </div>
      </div>
      <div class="auth-form-side">
        <div class="auth-form-header">
          <div class="auth-avatar"><i class="fas fa-user"></i></div>
          <h2>Login</h2>
        </div>

        <% if (error && error.length > 0) { %>
          <div class="form-alert form-alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
        <% } %>

        <form action="/auth/login" method="POST" class="auth-form">
          <div class="form-group">
            <input type="email" name="email" placeholder="Email" required class="form-input" />
          </div>
          <div class="form-group">
            <input type="password" name="password" placeholder="Password" required class="form-input" />
          </div>
          <button type="submit" class="btn btn-dark btn-block">Login</button>
          <p class="auth-switch">Don't have an account? <a href="/auth/register">Register</a></p>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
