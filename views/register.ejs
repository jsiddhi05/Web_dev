<%- include('partials/header') %>

<section class="auth-page">
  <div class="auth-bg" style="background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1400')"></div>
  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-illustration">
        <div class="illustration-content">
          <h2>Start Your Journey</h2>
          <p>Create an account and unlock a world of incredible travel experiences</p>
          <div class="auth-features">
            <div><i class="fas fa-check"></i> 50+ curated destinations</div>
            <div><i class="fas fa-check"></i> Instant booking confirmation</div>
            <div><i class="fas fa-check"></i> 24/7 travel support</div>
          </div>
        </div>
      </div>
      <div class="auth-form-side">
        <div class="auth-form-header">
          <div class="auth-avatar"><i class="fas fa-user-plus"></i></div>
          <h2>Register</h2>
        </div>

        <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
          <% errors.forEach(err => { %>
            <div class="form-alert form-alert-error"><i class="fas fa-exclamation-circle"></i> <%= err.msg %></div>
          <% }) %>
        <% } %>

        <form action="/auth/register" method="POST" class="auth-form">
          <div class="form-group">
            <input type="text" name="name" placeholder="Full Name" required value="<%= typeof name !== 'undefined' ? name : '' %>" class="form-input" />
          </div>
          <div class="form-group">
            <input type="email" name="email" placeholder="Email" required value="<%= typeof email !== 'undefined' ? email : '' %>" class="form-input" />
          </div>
          <div class="form-group">
            <input type="password" name="password" placeholder="Password (min 6 characters)" required class="form-input" />
          </div>
          <div class="form-group">
            <input type="password" name="password2" placeholder="Confirm Password" required class="form-input" />
          </div>
          <button type="submit" class="btn btn-dark btn-block">Create Account</button>
          <p class="auth-switch">Already have an account? <a href="/auth/login">Login</a></p>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
